# Auto-generated Dockerfile for ML model benchmarking
FROM {{ base_image | default("nvidia/cuda:12.6.2-devel-ubuntu22.04") }}

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# System dependencies
RUN apt-get update && apt-get upgrade -y && apt-get install -y --no-install-recommends --fix-missing \
    gcc g++ make \
    python3 python3-dev python3-pip python3-venv python3-wheel \
    espeak-ng libsndfile1-dev \
    git wget curl ffmpeg \
    libsm6 libxext6 \
    libglfw3-dev libgles2-mesa-dev \
    sysstat procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Create and activate virtual environment
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Upgrade build tools first
RUN pip install --upgrade wheel setuptools pip

{% if torch_install %}
# Install PyTorch (must come before project install for detectron2 etc.)
RUN {{ torch_install }}
{% endif %}

# Pre-install numpy (some packages need it at setup time)
RUN pip install numpy

{% if pip_requirements %}
# Install Python dependencies from requirements file
RUN pip install --no-cache-dir -r {{ pip_requirements }}
{% endif %}

{% if pre_install_commands %}
# Pre-install steps (submodules, third-party deps)
{% for cmd in pre_install_commands %}
RUN {{ cmd }}
{% endfor %}
{% endif %}

# Copy repo
COPY . /workspace/

{% if submodule_installs %}
# Install submodule packages
{% for cmd in submodule_installs %}
RUN {{ cmd }}
{% endfor %}
{% endif %}

{% if setup_commands %}
# Install project
{% for cmd in setup_commands %}
RUN {{ cmd }}
{% endfor %}
{% endif %}

{% if post_install_commands %}
# Post-install steps (data downloads, model fetching)
{% for cmd in post_install_commands %}
RUN {{ cmd }}
{% endfor %}
{% endif %}

# Copy benchmark entrypoint
COPY benchmark_entrypoint.sh /workspace/benchmark_entrypoint.sh
RUN chmod +x /workspace/benchmark_entrypoint.sh

ENTRYPOINT ["/workspace/benchmark_entrypoint.sh"]
