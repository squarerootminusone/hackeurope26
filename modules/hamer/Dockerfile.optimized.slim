FROM nvidia/cuda:11.8.0-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV FORCE_CUDA=1
ENV TORCH_CUDA_ARCH_LIST="8.0;8.9"
ENV PYOPENGL_PLATFORM=osmesa
ENV NVIDIA_DRIVER_CAPABILITIES=all

# System deps (includes fuse + gcsfuse prerequisites)
RUN apt-get update && apt-get install -y \
    python3.10 python3.10-venv python3.10-dev python3-pip \
    git wget unzip curl \
    libgl1-mesa-glx libglib2.0-0 libsm6 libxext6 libxrender-dev \
    libegl1-mesa-dev libgles2-mesa-dev \
    fuse lsb-release gnupg2 libosmesa6 \
    && rm -rf /var/lib/apt/lists/*

# Install gcsfuse
RUN export GCSFUSE_REPO="gcsfuse-jammy" && \
    echo "deb https://packages.cloud.google.com/apt $GCSFUSE_REPO main" \
      > /etc/apt/sources.list.d/gcsfuse.list && \
    curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg \
      | apt-key add - && \
    apt-get update && \
    apt-get install -y gcsfuse && \
    rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1 && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.10 1

RUN pip install --upgrade pip setuptools wheel

# Clone hamer
RUN git clone --recursive https://github.com/geopavlakos/hamer.git /app/hamer
WORKDIR /app/hamer

# Install PyTorch (CUDA 11.8)
RUN pip install torch torchvision --index-url https://download.pytorch.org/whl/cu118

# Install detectron2 first (needs torch in build env, so skip isolation)
RUN pip install 'git+https://github.com/facebookresearch/detectron2' --no-build-isolation

# Install hamer + ViTPose
RUN pip install -e ".[all]" --no-build-isolation && pip install -v -e third-party/ViTPose --no-build-isolation

# Update eval config paths to match container layout
RUN sed -i 's|/home/user/datasets/FreiHAND_pub_v2_eval/evaluation/rgb/|/datasets/FreiHAND/evaluation/rgb/|g' \
    hamer/configs/datasets_eval.yaml

# Skip renderer init during eval (avoids EGL/OSMesa dependency on headless servers)
RUN sed -i 's|model = HAMER.load_from_checkpoint(checkpoint_path, strict=False, cfg=model_cfg)|model = HAMER.load_from_checkpoint(checkpoint_path, strict=False, cfg=model_cfg, init_renderer=False)|g' \
    hamer/models/__init__.py

# Copy optimized modules over the originals
COPY optimized/ /app/hamer/hamer/models/optimized/

# Copy the optimized eval entry point
COPY optimized/eval_optimized.py /app/hamer/eval_optimized.py

# Entrypoint script (mounts GCS and creates symlinks)
COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

ENTRYPOINT ["/app/entrypoint.sh", "python"]
CMD ["eval_optimized.py", "--dataset", "FREIHAND-VAL"]
